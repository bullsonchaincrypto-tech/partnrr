# ============================================================
# Partnrr Server — Miljövariabler
# Kopiera denna fil till .env och fyll i dina värden
# ============================================================

# === DATABAS (Railway sätter denna automatiskt) ===
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === APPLIKATION ===
PORT=3001
NODE_ENV=production
CLIENT_URL=https://din-app.vercel.app

# === ANTHROPIC (Claude AI) — OBLIGATORISK ===
ANTHROPIC_API_KEY=sk-ant-api03-...

# === MICROSOFT OAUTH (Outlook e-post) ===
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://din-server.railway.app/api/auth/microsoft/callback

# === GMAIL OAUTH (alternativ till Microsoft) ===
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://din-server.railway.app/api/auth/gmail/callback

# === SÖKTJÄNSTER (valfritt men rekommenderat) ===
YOUTUBE_API_KEY=
SERPAPI_KEY=

# === SOCIALA MEDIER (valfritt) ===
APIFY_API_TOKEN=
INFLUENCERS_CLUB_API_KEY=
APOLLO_API_KEY=

# === PHYLLO (valfritt) ===
PHYLLO_CLIENT_ID=
PHYLLO_CLIENT_SECRET=

# ============================================================
# === V9 PIPELINE (Sprint 1+) ================================
# Inactive bakom USE_V9_PIPELINE=false. Sätt true för att aktivera.
# ============================================================

# Provider-nycklar — krävs när USE_V9_PIPELINE=true
SCRAPECREATORS_API_KEY=
HIKERAPI_TOKEN=
SERPER_API_KEY=

# Feature-flags
USE_V9_PIPELINE=false
USE_HIKERAPI_FALLBACK=false
V9_SEARCH_ROLLOUT_PCT=0
USE_QUERY_REFINEMENT=false
USE_HASHTAG_DISCOVERY=false
USE_LONG_TAIL_QUERIES=false
USE_COMMENT_DISCOVERY=false
USE_BIO_HARVEST=false
USE_LIST_DISCOVERY=false
USE_LOOKALIKE_EXPANSION=false
USE_FOF_LOOKALIKE=false
USE_OBSCURITY_VALIDATION=false

# Cap-konfiguration
V9_TARGET_MIN_RESULTS=20
V9_FINAL_CAP_MAX=40

# Alerts (valfritt — annars console.error)
PAGERDUTY_INTEGRATION_KEY=
SLACK_WEBHOOK_URL=
