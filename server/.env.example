# ============================================================
# Partnrr Server — Miljövariabler
# Kopiera denna fil till .env och fyll i dina värden
# ============================================================

# === DATABAS (Railway sätter denna automatiskt) ===
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === APPLIKATION ===
PORT=3001
NODE_ENV=production
CLIENT_URL=https://din-app.vercel.app

# === ANTHROPIC (Claude AI) — OBLIGATORISK ===
ANTHROPIC_API_KEY=sk-ant-api03-...

# === MICROSOFT OAUTH (Outlook e-post) ===
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://din-server.railway.app/api/auth/microsoft/callback

# === GMAIL OAUTH (alternativ till Microsoft) ===
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://din-server.railway.app/api/auth/gmail/callback

# === SÖKTJÄNSTER (valfritt men rekommenderat) ===
YOUTUBE_API_KEY=
SERPAPI_KEY=

# === SOCIALA MEDIER (valfritt) ===
APIFY_API_TOKEN=
INFLUENCERS_CLUB_API_KEY=
APOLLO_API_KEY=

# === PHYLLO (valfritt) ===
PHYLLO_CLIENT_ID=
PHYLLO_CLIENT_SECRET=
